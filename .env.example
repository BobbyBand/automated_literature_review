# Copy this file to .env and fill in only the values you need locally.
# Do not commit the real .env file.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=

# Local paths
ACL_ANTHOLOGY_DATA_DIR=./acl_anthology_data
KEYWORDS_FILE=./keywords.txt
PROMPT_FILE=./prompt.txt
INPUT_JSON=

# Pipeline settings
SOURCES=acl_anthology
ACL_BACKEND=auto
KEYWORD_MATCH_FIELD=title
MODELS=gpt-4.1-mini
MAX_RESULTS_PER_SOURCE=100
MAX_CLAUSES=64
REQUEST_TIMEOUT=30
SLEEP_SECONDS=0.5
MIN_SCORE=

# Generated outputs
OUTPUT_JSON=./outputs/ranked_papers.json
OUTPUT_CSV=./outputs/ranked_papers.csv
